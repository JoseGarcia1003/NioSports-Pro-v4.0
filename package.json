    "svelte":                   "^5.0.0",
    "vite":                     "^5.2.0",
    "tailwindcss":              "^3.4.0",
    "postcss":                  "^8.4.0",
    "autoprefixer":             "^10.4.0",
    "svelte-check":             "^3.6.0",
    "vitest":                   "^1.2.0",
    "eslint":                   "^8.57.0",
    "eslint-plugin-svelte":     "^2.35.0"
