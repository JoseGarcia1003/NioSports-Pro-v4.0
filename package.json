{
  "name": "niosports-pro",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "description": "Sistema predictivo NBA profesional — SvelteKit + Vite",
  "author": "Jose Garcia",
  "license": "MIT",

  "scripts": {
    "dev":        "vite dev",
    "build":      "vite build",
