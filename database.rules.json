{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "picks": {
          "$type": {
            ".validate": "$type === 'totales' || $type === 'ai' || $type === 'backtesting' || $type === 'props'",

            "$pickId": {
              ".validate": "newData.hasChildren(['status', 'createdAt'])",

              "localTeam": {
                ".validate": "newData.isString() && newData.val().length <= 60"
              },
              "awayTeam": {
                ".validate": "newData.isString() && newData.val().length <= 60"
              },
              "period": {
                ".validate": "newData.isString() && newData.val().length <= 10"
              },
              "betType": {
                ".validate": "newData.val() === 'OVER' || newData.val() === 'UNDER'"
              },
              "line": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999"
              },
              "projection": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999"
              },
              "probability": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1"
              },
              "probabilityPercent": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
              },
              "confidence": {
                ".validate": "newData.val() === 'HIGH' || newData.val() === 'MEDIUM' || newData.val() === 'LOW'"
              },
              "edge": {
                ".validate": "newData.isNumber() && newData.val() >= -50 && newData.val() <= 50"
              },
              "ev": {
                ".validate": "newData.isNumber() || newData.val() === null"
              },
              "evPercent": {
                ".validate": "newData.isNumber() || newData.val() === null"
              },
              "odds": {
                ".validate": "newData.isNumber() && newData.val() >= -10000 && newData.val() <= 10000"
              },
              "modelVersion": {
                ".validate": "newData.isString() && newData.val().length <= 20"
              },
              "source": {
                ".validate": "newData.isString() && newData.val().length <= 50"
              },
              "totalAdjustment": {
                ".validate": "newData.isNumber() || newData.val() === null"
              },
              "status": {
                ".validate": "newData.val() === 'pending' || newData.val() === 'win' || newData.val() === 'loss' || newData.val() === 'push'"
              },
              "closingLine": {
                ".validate": "newData.isNumber() || newData.val() === null"
              },
              "trend": {
                ".validate": "newData.isNumber() || newData.isString() || newData.val() === null"
              },
              "isCombo": {
                ".validate": "newData.isBoolean()"
              },
              "note": {
                ".validate": "newData.isString() && newData.val().length <= 500"
              },
              "createdAt": {
                ".validate": "newData.isString()"
              },
              "resolvedAt": {
                ".validate": "newData.isString() || newData.val() === null"
              },
              "actualResult": {
                ".validate": "newData.isNumber() || newData.val() === null"
              },
              "didBet": {
                ".validate": "newData.isBoolean()"
              },
              "betAmount": {
                ".validate": "newData.isNumber() && newData.val() >= 0 || newData.val() === null"
              },
              "actualTotal": {
                ".validate": "newData.isNumber() && newData.val() >= 0 || newData.val() === null"
              },
              "modelError": {
                ".validate": "newData.isNumber() || newData.val() === null"
              },
              "lineAtPick": {
                ".validate": "newData.isNumber() || newData.val() === null"
              },
              "lineRecordedAt": {
                ".validate": "newData.isString() || newData.val() === null"
              },
              "marketLine": {
                ".validate": "newData.isNumber() || newData.val() === null"
              }
            }
          }
        },

        "bankroll": {
          "current": {
            ".validate": "newData.isNumber() && newData.val() >= -10000000 && newData.val() <= 10000000"
          },
          "initial": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000000"
          },
          "lastSync": {
            ".validate": "newData.isString() || newData.val() === null"
          },
          "resetAt": {
            ".validate": "newData.isString() || newData.val() === null"
          },
          "history": {
            "$entryId": {
              ".validate": "newData.hasChildren(['date', 'type', 'amount', 'balance'])",
              "date": {
                ".validate": "newData.isString()"
              },
              "type": {
                ".validate": "newData.val() === 'deposit' || newData.val() === 'withdraw' || newData.val() === 'bet_win' || newData.val() === 'bet_loss' || newData.val() === 'bet_push'"
              },
              "amount": {
                ".validate": "newData.isNumber() && newData.val() >= 0"
              },
              "balance": {
                ".validate": "newData.isNumber()"
              },
              "note": {
                ".validate": "newData.isString() && newData.val().length <= 200 || newData.val() === null"
              },
              "pickId": {
                ".validate": "newData.isString() || newData.val() === null"
              }
            }
          }
        },

        "profile": {
          ".validate": "newData.hasChildren(['username'])",
          "username": {
            ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 30"
          },
          "displayName": {
            ".validate": "newData.isString() && newData.val().length <= 60"
          },
          "plan": {
            ".validate": "newData.val() === 'free' || newData.val() === 'pro' || newData.val() === 'elite'"
          },
          "createdAt": {
            ".validate": "newData.isString()"
          }
        },

        "preferences": {
          "theme": {
            ".validate": "newData.val() === 'dark' || newData.val() === 'light'"
          },
          "defaultOdds": {
            ".validate": "newData.isNumber()"
          },
          "notifications": {
            ".validate": "newData.isBoolean()"
          }
        }
      }
    },

    "usernamesIndex": {
      ".read": "auth != null",
      "$username": {
        ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 30",
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid)"
      }
    },

    "usernamesByUid": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.isString()"
      }
    }
  }
}