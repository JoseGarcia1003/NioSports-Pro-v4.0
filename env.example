# .env.example — NioSports Pro v4.0
# Copy as .env.local and fill all values. NEVER commit .env.local.

# Firebase Auth (client-side)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_DATABASE_URL=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# Supabase (Fase 1)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# BallDontLie API (server only)
BALLDONTLIE_API_KEY=

# The Odds API (server only, optional)
ODDS_API_KEY=

# Proxy HMAC secret (server only) — openssl rand -hex 32
NS_PROXY_SECRET=

# Upstash Redis (server only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron secret (server only) — openssl rand -hex 32
CRON_SECRET=

# Sentry (optional)
SENTRY_DSN=
